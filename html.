// ─── B: HCS GRAPH ───
const HCS_HISTORY=[];
const HCS_MAX=120;

function drawHCSGraph(){
  const cv=document.getElementById('hcsCanvas');
  const W=cv.parentElement.clientWidth-80;
  const H=28;
  if(W<10)return;
  cv.width=W;cv.height=H;
  const ctx=cv.getContext('2d');
  ctx.fillStyle='#080c12';ctx.fillRect(0,0,W,H);

  if(HCS_HISTORY.length<2)return;

  // Threshold lines
  ctx.strokeStyle='rgba(255,34,68,0.3)';ctx.lineWidth=1;ctx.setLineDash([2,2]);
  ctx.beginPath();ctx.moveTo(0,H-(0.7*H));ctx.lineTo(W,H-(0.7*H));ctx.stroke();
  ctx.setLineDash([]);

  // HCS line
  const n=HCS_HISTORY.length;
  ctx.beginPath();
  HCS_HISTORY.forEach((v,i)=>{
    const x=(i/(HCS_MAX-1))*W;
    const y=H-(v*H*0.9)-2;
    i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
  });
  const last=HCS_HISTORY[HCS_HISTORY.length-1];
  ctx.strokeStyle=last>0.7?'#ff4466':last>0.4?'#ffd700':'#00ff88';
  ctx.lineWidth=1.5;ctx.stroke();

  // Alert
  const alertEl=document.getElementById('hcsAlert');
  if(alertEl)alertEl.style.display=last>=0.8?'block':'none';

  // Alert sound (Web Audio)
  if(last>=0.8&&HCS_HISTORY.length>2){
    const prev=HCS_HISTORY[HCS_HISTORY.length-2];
    if(prev<0.8)playAlert();
  }
}

let audioCtx=null;
function playAlert(){
  try{
    if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();
    const osc=audioCtx.createOscillator();
    const gain=audioCtx.createGain();
    osc.connect(gain);gain.connect(audioCtx.destination);
    osc.frequency.value=880;
    gain.gain.setValueAtTime(0.3,audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001,audioCtx.currentTime+0.4);
    osc.start();osc.stop(audioCtx.currentTime+0.4);
  }catch(e){}
}



