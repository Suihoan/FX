    }
  };
  reader.readAsText(file,'latin-1'); // latin-1 handles both UTF-8 and Shift-JIS ASCII ranges
}

function parseCSV(text){
  const lines=text.split(/\r?\n/);
  const res=[];
  for(const line of lines){
    const t=line.trim();
    if(!t)continue;
    // Skip header/comment lines (HistData status report lines)
    if(t.startsWith('H')||t.startsWith('F')||t.startsWith('G')||
       t.startsWith('A')||t.startsWith('M')||t.startsWith('<'))continue;
    // HistData format: "20080915 093000,104.35,104.40,104.30,104.35,150"
    // Replace first space (between date and time) with comma
    const normalized=t.replace(/^(\d{8}) /,'$1,');
    const parts=normalized.split(',');
    if(parts.length<5)continue;
    let dt,o,h,l,c,v=0;
    if(parts.length>=6){
      // Check if parts[1] is a time (6 digits) or a price
      const isTime = parts.length>=7 && /^\d{6}$/.test(parts[1]);
      if(isTime){
        // Format: date, time, o, h, l, c, v
        dt=parts[0]+parts[1];
        o=parseFloat(parts[2]);h=parseFloat(parts[3]);
        l=parseFloat(parts[4]);c=parseFloat(parts[5]);
      } else {
        // Format: datetime(14chars), o, h, l, c, v
        dt=parts[0];
        o=parseFloat(parts[1]);h=parseFloat(parts[2]);
        l=parseFloat(parts[3]);c=parseFloat(parts[4]);
      }
    } else continue;
    if(isNaN(o)||isNaN(c)||c===0)continue;
    res.push({dt,o,h,l,c});
  }
  return res;
}

function playCSV(){
  stopCSV();
  const sel=document.getElementById('csvEvt');
  const evtIdx=sel.value===''?(csvLoopEnabled&&csvLoopStart>0?csvLoopStart:0):parseInt(sel.value);
  csvIdx=Math.max(0,evtIdx-120);
  // Apply range if set
  if(csvLoopEnabled&&csvLoopStart>0) csvIdx=Math.max(0,csvLoopStart-120);
  // Preload buffer
  buf1m=[];prices=[];
  const pre=Math.min(12000,csvIdx);
  const preStart=Math.max(0,csvIdx-pre);
  for(let i=preStart;i<csvIdx;i++){
    const d=csvData[i];
    buf1m.push({o:d.o,h:d.h,l:d.l,c:d.c,dt:d.dt});
    prices.push(d.c);
  }
  // If starting from beginning, add at least the first candle
  if(!prices.length&&csvData.length){
    prices.push(csvData[0].c);
    buf1m.push({o:csvData[0].o,h:csvData[0].h,l:csvData[0].l,c:csvData[0].c,dt:csvData[0].dt});
  }
  const spd=parseInt(document.getElementById('csvSpd').value)||500;
  csvTimer=setInterval(advCSV,getCsvInterval());
  document.getElementById('playBtn').textContent='⏸ Stop';
  playing=true;
}

function advCSV(){
  const loopEnd=csvLoopEnabled&&csvLoopEnd>0?csvLoopEnd:csvData.length;
  if(csvIdx>=loopEnd){
    if(csvLoopEnabled&&csvLoopStart>=0){
      // Loop: jump back to start position
      csvIdx=csvLoopStart;
      buf1m=[];prices=[];
      const pre=Math.min(12000,csvIdx);
      for(let i=Math.max(0,csvIdx-pre);i<csvIdx;i++){
        const d=csvData[i];
        buf1m.push({o:d.o,h:d.h,l:d.l,c:d.c,dt:d.dt});
        prices.push(d.c);
      }
      return;
    }
    stopCSV();return;
  }
  const d=csvData[csvIdx];
  buf1m.push({o:d.o,h:d.h,l:d.l,c:d.c,dt:d.dt});
  if(buf1m.length>12000)buf1m.shift();
  prices.push(d.c);
  if(prices.length>80000)prices.shift();
  csvIdx++;
  if(csvIdx%5===0){
    const dt=d.dt;
    const s=`${dt.substring(0,4)}/${dt.substring(4,6)}/${dt.substring(6,8)} ${dt.length>=12?dt.substring(8,10):'--'}:${dt.length>=14?dt.substring(10,12):'--'}  ${fmt(d.c)}`;
    document.getElementById('csvSt').textContent=s;
    document.getElementById('playhead').textContent=s;
  }
}

function stopCSV(){
  if(csvTimer){clearInterval(csvTimer);csvTimer=null;}
  if(simTimer){clearInterval(simTimer);simTimer=null;}
  playing=false;
  document.getElementById('playBtn').textContent='▶ Play';
}

function seekCSV(mins){
  const wasPlaying=!!csvTimer;
  stopCSV();
  csvIdx=Math.max(0,Math.min(csvData.length-1,csvIdx+mins));
  buf1m=[];prices=[];
  const pre=Math.min(12000,csvIdx);
  for(let i=Math.max(0,csvIdx-pre);i<csvIdx;i++){
    const d=csvData[i];
    buf1m.push({o:d.o,h:d.h,l:d.l,c:d.c,dt:d.dt});
    prices.push(d.c);
  }
  if(!prices.length&&csvData.length)prices.push(csvData[0].c);
  if(wasPlaying)playCSV();
}

