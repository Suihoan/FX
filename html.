function textColor(){ return document.body.classList.contains('light')?'rgba(0,0,0,0.4)':'rgba(255,255,255,0.25)'; }

// ─── THEME TOGGLE ───
let isDark = true;
function toggleTheme(){
  isDark = !isDark;
  document.body.classList.toggle('light', !isDark);
  const btn = document.getElementById('themeBtn');
  if(btn) btn.textContent = isDark ? '🌙' : '☀️';
  try{ localStorage.setItem('cv_theme', isDark?'dark':'light'); }catch(e){}
}
// Load saved theme
try{
  const saved = localStorage.getItem('cv_theme');
  if(saved === 'light'){ isDark=false; document.body.classList.add('light');
    setTimeout(()=>{ const b=document.getElementById('themeBtn'); if(b)b.textContent='☀️'; },50);
  }
}catch(e){}

// ─── START ───
initSim();
loadSettings();
updateTicker('normal');
render();
</script>
