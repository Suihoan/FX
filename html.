<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, viewport-fit=cover">
<meta name="theme-color" content="#080c12">
<title>CHART VIEWER — STATUS / Dear Otaku, IV</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Noto+Sans+JP:wght@400;700&display=swap');
:root {
  --bg:#080c12; --panel:#0c1018; --border:#1a2535;
  --up:#4da6ff; --dn:#ff4466;
  --ma1:#00ff88; --ma2:#ffd700; --ma3:#ff8844;
  --gold:#ffd700; --dim:rgba(255,255,255,0.4);
  --text:#ccddef; --green:#00ff88; --danger:#ff2244;
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;overflow:hidden;}
body{
  background:var(--bg);color:var(--text);
  font-family:'Share Tech Mono',monospace;
  display:flex;flex-direction:column;
  height:100dvh;
}
/* ── TOP BAR ── */
.topbar{
  display:flex;align-items:center;justify-content:space-between;
  padding:5px 10px;background:#05080e;
  border-bottom:1px solid var(--border);flex-shrink:0;
}
.app-title{font-size:0.95rem;color:var(--gold);letter-spacing:0.1em;}
.app-sub{font-size:0.45rem;color:var(--dim);}
.price-block{text-align:right;}
.price-pair{font-size:0.5rem;color:var(--dim);}
.price-main{font-size:1.1rem;font-weight:bold;transition:color 0.2s;}
.price-chg{font-size:0.58rem;}

/* ── LAYOUT BAR ── */
.bar{
  display:flex;align-items:center;gap:5px;
  padding:3px 8px;background:#05080e;
  border-bottom:1px solid var(--border);flex-shrink:0;flex-wrap:wrap;
}
.bar-label{font-size:0.45rem;color:var(--dim);letter-spacing:0.1em;white-space:nowrap;}
.xbtn{
  padding:2px 8px;font-size:0.55rem;
  border:1px solid var(--border);background:transparent;
  color:var(--dim);cursor:pointer;border-radius:3px;
  font-family:'Share Tech Mono',monospace;transition:all 0.15s;white-space:nowrap;
}
.xbtn:hover,.xbtn.on{border-color:var(--gold);color:var(--gold);background:rgba(255,215,0,0.08);}
.xbtn.play{background:linear-gradient(135deg,#0055cc,#003388);color:white;border-color:#0066ff;min-width:60px;}
.xbtn.play:hover{background:linear-gradient(135deg,#0077ff,#0055cc);}

/* ── CHARTS GRID ── */
.grid{
  display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;
  flex:1;gap:1px;background:var(--border);min-height:0;overflow:hidden;
}
.grid.l1{grid-template-columns:1fr;grid-template-rows:1fr;}
.grid.l2h{grid-template-columns:1fr 1fr;grid-template-rows:1fr;}
.grid.l2v{grid-template-columns:1fr;grid-template-rows:1fr 1fr;}
.grid.l3{grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;}
.grid.l4{grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;}

.panel{
  background:var(--panel);display:flex;flex-direction:column;
  min-height:0;overflow:hidden;position:relative;
}
/* Hide panels based on layout */
.grid.l1 .panel:nth-child(n+2){display:none;}
.grid.l2h .panel:nth-child(n+3){display:none;}
.grid.l2v .panel:nth-child(n+3){display:none;}
.grid.l3 .panel:nth-child(4){display:none;}
.grid.l3 .panel:nth-child(3){grid-column:1/3;}

.ph{ /* panel header */
  display:flex;align-items:center;gap:5px;
  padding:3px 7px;background:rgba(0,0,0,0.5);
  border-bottom:1px solid var(--border);flex-shrink:0;
}
.ph select{
  font-family:'Share Tech Mono',monospace;font-size:0.58rem;
  background:#080e1a;color:var(--gold);
  border:1px solid rgba(255,215,0,0.25);padding:1px 3px;
  border-radius:3px;outline:none;
}
.ph-angle{font-size:0.6rem;font-weight:bold;margin-left:auto;}

.mah{ /* MA header */
  display:flex;align-items:center;gap:4px;
  padding:2px 7px;background:rgba(0,0,0,0.3);
  border-bottom:1px solid rgba(255,255,255,0.04);flex-shrink:0;
}
.mg{display:flex;align-items:center;gap:2px;}
.mdot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.ml{font-size:0.42rem;color:var(--dim);}
.mi{
  width:30px;font-family:'Share Tech Mono',monospace;font-size:0.58rem;
  background:#080e1a;color:var(--gold);
  border:1px solid rgba(255,215,0,0.2);
  padding:1px 2px;border-radius:2px;outline:none;text-align:center;
}
.mi:focus{border-color:rgba(255,215,0,0.6);}
.meye{
  font-size:0.5rem;background:transparent;border:none;
  cursor:pointer;opacity:0.65;padding:0 1px;line-height:1;
}
.meye:hover{opacity:1;}
.meye.off{opacity:0.2;}

.ptag{ /* price tag on chart */
  position:absolute;right:2px;z-index:5;
  font-size:0.55rem;background:rgba(255,215,0,0.15);
  color:var(--gold);padding:1px 4px;border-radius:2px;
  border:1px solid rgba(255,215,0,0.3);
}
canvas{display:block;flex:1;width:100%;min-height:0;}

/* ── ANALYZER STRIP ── */
.astrip{
  display:flex;align-items:center;gap:5px;
  padding:3px 8px;background:#05080e;
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
  flex-shrink:0;overflow-x:auto;scrollbar-width:none;
}
.astrip::-webkit-scrollbar{display:none;}
.atitle{font-size:0.5rem;color:rgba(100,180,255,0.8);letter-spacing:0.15em;white-space:nowrap;}
.hcs{font-size:0.9rem;white-space:nowrap;}
.achips{display:flex;gap:3px;}
.ac{
  padding:2px 5px;border-radius:3px;font-size:0.56rem;
  background:rgba(255,255,255,0.05);border:1px solid transparent;white-space:nowrap;
}
.apills{display:flex;gap:4px;margin-left:auto;}
.pill{
  padding:2px 9px;border-radius:12px;font-size:0.68rem;white-space:nowrap;
}
.pfake{background:rgba(0,255,136,0.1);color:var(--green);border:1px solid rgba(0,255,136,0.3);}
.ppanic{background:rgba(255,34,68,0.1);color:var(--danger);border:1px solid rgba(255,34,68,0.3);}

/* ── PLAYBACK BAR ── */
.pbar{
  display:flex;flex-direction:column;gap:5px;
  padding:5px 8px;background:#05080e;
  border-top:1px solid var(--border);flex-shrink:0;
  padding-bottom:max(5px,env(safe-area-inset-bottom));
}
.prow{display:flex;gap:5px;align-items:center;flex-wrap:wrap;}

/* ── SPREAD BAR ── */
.sbar{
  display:flex;align-items:center;gap:6px;
  padding:3px 8px;background:#05080e;
  border-top:1px solid var(--border);flex-shrink:0;flex-wrap:wrap;
}
.sinp{
  width:40px;font-family:'Share Tech Mono',monospace;font-size:0.62rem;
  background:#080e1a;color:var(--gold);
  border:1px solid rgba(255,215,0,0.25);
  padding:2px 3px;border-radius:3px;outline:none;text-align:center;
}
.bidask{margin-left:auto;display:flex;gap:8px;align-items:center;font-size:0.6rem;}
.bid{color:var(--dn);}
.ask{color:var(--up);}
.spreadlive{font-size:0.52rem;color:var(--gold);}

/* ── CSV BAR ── */
.csvbar{
  display:flex;align-items:center;gap:6px;
  padding:3px 8px;background:rgba(0,80,200,0.08);
  border-top:1px solid rgba(0,150,255,0.15);flex-shrink:0;flex-wrap:wrap;
}
.csvbtn{
  padding:3px 10px;font-size:0.68rem;
  background:linear-gradient(135deg,#0055cc,#0033aa);
  color:white;border:none;border-radius:3px;cursor:pointer;white-space:nowrap;
}
.csvbtn:hover{background:linear-gradient(135deg,#0077ff,#0055cc);}
.csvst{font-size:0.52rem;color:var(--dim);}
.csvst.ok{color:var(--green);}
.csvst.err{color:var(--danger);}
.csvrng{display:flex;gap:4px;align-items:center;margin-left:auto;}
.csvsel{
  font-family:'Share Tech Mono',monospace;font-size:0.55rem;
  background:#080e1a;color:var(--gold);
  border:1px solid rgba(255,215,0,0.25);
  padding:2px 4px;border-radius:3px;outline:none;
}
input[type=file]#csvFile{display:none;}

/* ── NEWS TICKER ── */
.ticker-wrap{
  overflow:hidden;white-space:nowrap;background:#000;
  border-bottom:1px solid var(--border);flex-shrink:0;
  padding:2px 0;
}
.ticker-inner{
  display:inline-block;padding-left:100%;
  animation:scroll-news 35s linear infinite;
  font-size:0.52rem;color:#00ff88;letter-spacing:0.05em;
}
@keyframes scroll-news{
  0%{transform:translateX(0);}
  100%{transform:translateX(-100%);}
}

/* ── HCS GRAPH ── */
.hcs-graph-wrap{
  display:flex;align-items:center;gap:6px;
  padding:2px 8px;background:#05080e;
  border-top:1px solid var(--border);flex-shrink:0;
}
.hcs-graph-label{font-size:0.45rem;color:var(--dim);white-space:nowrap;}
#hcsCanvas{height:28px;flex:1;}



/* ── RESPONSIVE ── */
@media(max-width:480px) and (orientation:portrait){
  /* l4: 1 col, 4 rows */
  .grid.l4{grid-template-columns:1fr;grid-template-rows:repeat(4,1fr);}
  /* l3: 1 col, 3 rows */
  .grid.l3{grid-template-columns:1fr;grid-template-rows:repeat(3,1fr);}
  .grid.l3 .panel:nth-child(3){grid-column:auto;}
  /* l2h: keep horizontal as selected */
  /* l2v: keep vertical */
}

/* ── OBSERVATION LOG ── */
.log-bar{display:flex;align-items:center;gap:6px;padding:3px 8px;background:#03060e;border-top:1px solid var(--border);flex-shrink:0;flex-wrap:wrap;}
.log-btn{padding:3px 10px;font-size:0.62rem;background:linear-gradient(135deg,#1a3a1a,#0a2a0a);color:#00ff88;border:1px solid #00ff8844;border-radius:3px;cursor:pointer;white-space:nowrap;}
.log-btn:hover{background:linear-gradient(135deg,#2a5a2a,#1a4a1a);}
.log-note{font-family:'Share Tech Mono',monospace;font-size:0.6rem;background:#080e1a;color:var(--text);border:1px solid rgba(255,255,255,0.15);padding:2px 6px;border-radius:3px;outline:none;flex:1;min-width:120px;}
.log-note::placeholder{color:var(--dim);}
.log-rating{display:flex;gap:3px;}
.log-star{font-size:0.8rem;cursor:pointer;opacity:0.3;transition:opacity 0.15s;background:none;border:none;padding:0;}
.log-star.on{opacity:1;}
.log-eval{font-size:0.9rem;cursor:pointer;opacity:0.3;transition:all 0.15s;background:none;border:none;padding:0 2px;}
.log-eval.on{opacity:1;filter:drop-shadow(0 0 3px #ffd700);}
.log-count{font-size:0.5rem;color:var(--dim);}
.log-modal{position:fixed;inset:0;background:rgba(0,0,0,0.88);backdrop-filter:blur(6px);z-index:800;display:none;align-items:flex-start;justify-content:center;padding-top:40px;overflow-y:auto;}
.log-modal.show{display:flex;}
.log-card{width:min(420px,94vw);background:linear-gradient(135deg,#060d1a,#0a1a30);border:1px solid var(--border);border-radius:10px;padding:16px;animation:pop-in 0.3s cubic-bezier(0.34,1.56,0.64,1);}
.log-card-title{font-size:0.8rem;color:var(--gold);letter-spacing:0.15em;border-bottom:1px solid var(--border);padding-bottom:8px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center;}
.log-close{background:none;border:none;color:var(--dim);cursor:pointer;font-size:1rem;}
.log-table{width:100%;border-collapse:collapse;font-size:0.58rem;}
.log-table th{text-align:left;color:var(--dim);font-weight:normal;padding:4px 6px;border-bottom:1px solid var(--border);letter-spacing:0.1em;}
.log-table td{padding:5px 6px;border-bottom:1px solid rgba(255,255,255,0.04);color:var(--text);vertical-align:top;}
.log-table tr:hover td{background:rgba(255,255,255,0.03);}
.log-hcs-hi{color:#ff4466;}.log-hcs-md{color:#ffd700;}.log-hcs-lo{color:#00ff88;}
.log-clear-btn{margin-top:10px;width:100%;padding:6px;font-size:0.58rem;background:rgba(255,0,50,0.1);color:#ff4466;border:1px solid #ff446644;border-radius:4px;cursor:pointer;font-family:'Share Tech Mono',monospace;}
.log-export-btn{margin-top:6px;width:100%;padding:6px;font-size:0.58rem;background:rgba(0,255,136,0.08);color:#00ff88;border:1px solid #00ff8844;border-radius:4px;cursor:pointer;font-family:'Share Tech Mono',monospace;}
.log-empty{text-align:center;color:var(--dim);font-size:0.6rem;padding:20px;}

/* ── LIGHT MODE ── */
body.light{
  --bg:#f0f2f5; --panel:#ffffff; --border:#d0d8e8;
  --up:#1a6bcc; --dn:#cc2244;
  --ma1:#009955; --ma2:#cc8800; --ma3:#cc5500;
  --gold:#996600; --dim:rgba(0,0,0,0.4);
  --text:#1a2535; --green:#009955; --danger:#cc2244;
  background:var(--bg);color:var(--text);
}
body.light .topbar,body.light .ctrlbar,body.light .bar,
body.light .astrip,body.light .pbar,body.light .sbar,
body.light .csvbar,body.light .log-bar,body.light .finder-bar{
  background:#e8ecf2;border-color:var(--border);
}
body.light .panel{background:#ffffff;}
body.light .ph{background:rgba(0,0,0,0.04);}
body.light .mah{background:rgba(0,0,0,0.03);}
body.light .grid{background:var(--border);}
body.light .xbtn{color:rgba(0,0,0,0.5);border-color:var(--border);}
body.light .xbtn.on,body.light .xbtn:hover{color:var(--gold);border-color:var(--gold);background:rgba(150,100,0,0.08);}
body.light .mi{background:#ffffff;color:#664400;border-color:rgba(0,0,0,0.2);}
body.light .app-title{color:#664400;}
body.light .price-main{color:#1a2535;}
body.light canvas{background:#ffffff;}
body.light .log-card{background:linear-gradient(135deg,#f8f9fc,#eef1f8);}
body.light .log-note{background:#ffffff;color:#1a2535;border-color:rgba(0,0,0,0.2);}
body.light{
  --ma1:#007744; --ma2:#886600; --ma3:#993300;
}
body.light .ptag{background:rgba(150,100,0,0.12);color:#664400;border-color:rgba(150,100,0,0.3);}
body.light .astrip,body.light .hcs-graph-wrap{background:#e8ecf2;}
body.light .danger-overlay.safe{background:transparent;}
body.light .danger-overlay.caution{background:transparent;}
body.light .danger-overlay.danger{background:transparent;}
body.light .finder-bar{background:#e0e4ec;}
body.light .ticker-wrap{background:#f5f5f5;}
body.light .ticker-inner{color:#009955;}

/* Mode toggle button */
.mode-btn{
  font-family:'Share Tech Mono',monospace;font-size:0.52rem;
  padding:1px 7px;border-radius:3px;cursor:pointer;
  border:1px solid rgba(255,255,255,0.15);
  background:transparent;color:rgba(255,255,255,0.5);
  transition:all 0.15s;white-space:nowrap;
}
.mode-btn:hover{border-color:var(--gold);color:var(--gold);}
.mode-btn.hinkua{
  border-color:rgba(204,136,255,0.7);
  color:#cc88ff;
  background:rgba(204,136,255,0.1);
}
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="topbar">
  <div>
    <div class="app-title">📊 CHART VIEWER</div>
    <div class="app-sub">STATUS / Dear Otaku, IV — Lukewarm Walker, A Japanese</div>
  </div>
  <div class="price-block">
    <div class="price-pair" id="pairLabel">USD/JPY</div>
    <div class="price-main" id="priceMain">—</div>
    <div class="price-chg" id="priceChg">—</div>
  </div>
</div>

<!-- NEWS TICKER -->
<div class="ticker-wrap" id="tickerWrap">
  <div class="ticker-inner" id="tickerText">　</div>
</div>

<!-- LAYOUT BAR -->
<div class="bar">
  <span class="bar-label">Layout:</span>
  <button class="xbtn" onclick="setLayout('l1')" id="ll1">1 Panel</button>
  <button class="xbtn" onclick="setLayout('l2h')" id="ll2h">2 Horiz</button>
  <button class="xbtn" onclick="setLayout('l2v')" id="ll2v">2 Vert</button>
  <button class="xbtn" onclick="setLayout('l3')" id="ll3">3 Panel</button>
  <button class="xbtn on" onclick="setLayout('l4')" id="ll4">4 Panel</button>
  <button class="xbtn" id="themeBtn" onclick="toggleTheme()" title="Toggle Light/Dark" style="margin-left:auto">🌙</button>
  <span class="bar-label" style="margin-left:8px">Scenario:</span>
  <button class="xbtn on" onclick="setScen('normal')" id="sn">Normal</button>
  <button class="xbtn" onclick="setScen('fake')" id="sf">🎣 Fake</button>
  <button class="xbtn" onclick="setScen('panic')" id="sp">💥 Panic</button>
  <button class="xbtn" onclick="setScen('lehman')" id="sl">📉 Lehman</button>
  <button class="xbtn" onclick="setScen('intv')" id="si">🏦 Intv</button>
</div>

<!-- CHARTS GRID -->
<div class="grid l4" id="grid">
  <!-- Panel 0 -->
  <div class="panel">
    <div class="ph">
      <select id="tf0" onchange="setTF(0,+this.value)"></select>
      <button class="mode-btn" id="mode0" onclick="toggleMode(0)">📊 Normal</button>
      <div class="ph-angle" id="ang0">—</div>
    </div>
    <div class="mah">
      <div class="mg"><div class="mdot" style="background:var(--ma1)"></div><span class="ml">S</span><input class="mi" id="ma00" value="5" type="number" min="1" max="500"><button class="meye" id="me00" onclick="toggleEye(0,0)">👁</button></div>
      <div class="mg"><div class="mdot" style="background:var(--ma2)"></div><span class="ml">M</span><input class="mi" id="ma01" value="13" type="number" min="1" max="500"><button class="meye" id="me01" onclick="toggleEye(0,1)">👁</button></div>
      <div class="mg"><div class="mdot" style="background:var(--ma3)"></div><span class="ml">L</span><input class="mi" id="ma02" value="25" type="number" min="1" max="500"><button class="meye" id="me02" onclick="toggleEye(0,2)">👁</button></div>
    </div>
    <div class="ptag" id="pt0" style="top:46px">—</div>
    <canvas id="cv0"></canvas>
  </div>
  <!-- Panel 1 -->
  <div class="panel">
    <div class="ph">
      <select id="tf1" onchange="setTF(1,+this.value)"></select>
      <button class="mode-btn" id="mode1" onclick="toggleMode(1)">📊 Normal</button>
      <div class="ph-angle" id="ang1">—</div>
    </div>
    <div class="mah">
      <div class="mg"><div class="mdot" style="background:var(--ma1)"></div><span class="ml">S</span><input class="mi" id="ma10" value="5" type="number" min="1" max="500"><button class="meye" id="me10" onclick="toggleEye(1,0)">👁</button></div>
      <div class="mg"><div class="mdot" style="background:var(--ma2)"></div><span class="ml">M</span><input class="mi" id="ma11" value="15" type="number" min="1" max="500"><button class="meye" id="me11" onclick="toggleEye(1,1)">👁</button></div>
      <div class="mg"><div class="mdot" style="background:var(--ma3)"></div><span class="ml">L</span><input class="mi" id="ma12" value="30" type="number" min="1" max="500"><button class="meye" id="me12" onclick="toggleEye(1,2)">👁</button></div>
    </div>
    <div class="ptag" id="pt1" style="top:46px">—</div>
    <canvas id="cv1"></canvas>
  </div>
  <!-- Panel 2 -->
  <div class="panel">
    <div class="ph">
      <select id="tf2" onchange="setTF(2,+this.value)"></select>
      <button class="mode-btn" id="mode2" onclick="toggleMode(2)">📊 Normal</button>
      <div class="ph-angle" id="ang2">—</div>
    </div>
    <div class="mah">
      <div class="mg"><div class="mdot" style="background:var(--ma1)"></div><span class="ml">S</span><input class="mi" id="ma20" value="7" type="number" min="1" max="500"><button class="meye" id="me20" onclick="toggleEye(2,0)">👁</button></div>
      <div class="mg"><div class="mdot" style="background:var(--ma2)"></div><span class="ml">M</span><input class="mi" id="ma21" value="21" type="number" min="1" max="500"><button class="meye" id="me21" onclick="toggleEye(2,1)">👁</button></div>
      <div class="mg"><div class="mdot" style="background:var(--ma3)"></div><span class="ml">L</span><input class="mi" id="ma22" value="42" type="number" min="1" max="500"><button class="meye" id="me22" onclick="toggleEye(2,2)">👁</button></div>
    </div>
    <div class="ptag" id="pt2" style="top:46px">—</div>
    <canvas id="cv2"></canvas>
  </div>
  <!-- Panel 3 -->
  <div class="panel">
    <div class="ph">
      <select id="tf3" onchange="setTF(3,+this.value)"></select>
      <button class="mode-btn" id="mode3" onclick="toggleMode(3)">📊 Normal</button>
      <div class="ph-angle" id="ang3">—</div>
    </div>
    <div class="mah">
