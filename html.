      csvData=parseCSV(e.target.result);
      if(!csvData.length)throw new Error('No data found');
      // Detect pair from filename
      const fn=file.name.toUpperCase();
      const pairs=[['EURUSD','EUR/USD'],['GBPUSD','GBP/USD'],['USDJPY','USD/JPY'],
        ['AUDUSD','AUD/USD'],['USDCHF','USD/CHF'],['USDCAD','USD/CAD'],
        ['NZDUSD','NZD/USD'],['EURJPY','EUR/JPY'],['GBPJPY','GBP/JPY'],
        ['AUDJPY','AUD/JPY'],['EURGBP','EUR/GBP'],['XAUUSD','XAU/USD']];
      pairName='FX';
      for(const [k,v] of pairs){if(fn.includes(k)){pairName=v;break;}}
      document.getElementById('pairLabel').textContent=pairName;
      // Detect decimals
      const sp=csvData[Math.floor(csvData.length/2)].c;
      dec=sp>=10?3:5;
      pipU=pairName.includes('JPY')?0.01:0.0001;
      // Populate event selector
      const sel=document.getElementById('csvEvt');
      sel.innerHTML='<option value="">── Select Event ──</option>';
      Object.entries(EVENTS).forEach(([date,ev])=>{
        const tgt=parseInt(date);
        let best=-1,bestDiff=Infinity;
        csvData.forEach((d,i)=>{
          const d8=parseInt(d.dt.substring(0,8));
          const diff=Math.abs(d8-tgt);
          if(diff<bestDiff&&diff<=7){bestDiff=diff;best=i;}
        });
        if(best>=0){
          const o=document.createElement('option');
          o.value=best;o.textContent=ev.lb;
          sel.appendChild(o);
        }
      });
      // Full period
      const oAll=document.createElement('option');
      oAll.value='0';oAll.textContent='Full Period';
      sel.insertBefore(oAll,sel.children[1]);

      const first=csvData[0].dt,last=csvData[csvData.length-1].dt;
      st.textContent=`✅ ${pairName} ${csvData.length.toLocaleString()} bars (${first.substring(0,8)} - ${last.substring(0,8)})`;
      st.className='csvst ok';
